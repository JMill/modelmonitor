{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jmill.github.io/modelmonitor/schema.json",
  "title": "modelmonitor manifest",
  "type": "object",
  "required": ["version", "generated_at", "providers"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "1" },
    "generated_at": { "type": "string", "format": "date-time" },
    "providers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/providerSnapshot" }
    }
  },
  "definitions": {
    "providerSnapshot": {
      "type": "object",
      "required": ["families"],
      "properties": {
        "families": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/family" }
        }
      }
    },
    "family": {
      "type": "object",
      "required": ["recommended", "all"],
      "properties": {
        "recommended": { "type": "string" },
        "all": {
          "type": "array",
          "items": { "$ref": "#/definitions/modelInfo" }
        }
      }
    },
    "modelInfo": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "display_name": { "type": "string" },
        "created_at": { "type": "string" },
        "deprecated": { "type": "boolean" }
      }
    }
  }
}
