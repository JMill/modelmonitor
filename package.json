{
  "name": "modelmonitor",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-provider model freshness service: publishes a manifest and opens PRs when pinned models go stale.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "tsx scripts/check-models.ts",
    "bump-prs": "tsx scripts/open-bump-prs.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@octokit/rest": "^21.0.0",
    "js-yaml": "^4.1.0",
    "openai": "^4.77.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
